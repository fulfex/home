---
export interface Props {
	lang?: 'en' | 'id';
}

const { lang = 'en' } = Astro.props;

const isID = lang === 'id';
const url = Astro.url;

const enUrl = new URL(url);
enUrl.pathname = '/';
const idUrl = new URL(url);
idUrl.pathname = '/id/';

const title = 'Fulfex — Storefront template for WordPress';
const desc = isID
	? 'Storefront template open-source yang langsung jalan dengan WordPress API. Konfigurasi warna, font, dan branding ala shadcn.'
	: 'An open-source storefront template that connects to your WordPress API out of the box. Configure colors, fonts, and branding shadcn-style.';
const ogLocale = isID ? 'id_ID' : 'en_US';
const primaryUrl = isID ? idUrl : enUrl;
const alternateUrl = isID ? enUrl : idUrl;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={desc} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={primaryUrl.toString()} />
		<link rel="alternate" hreflang={isID ? 'id' : 'en'} href={primaryUrl.toString()} />
		<link rel="alternate" hreflang={isID ? 'en' : 'id'} href={alternateUrl.toString()} />
		<link rel="alternate" hreflang="x-default" href={enUrl.toString()} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={primaryUrl.toString()} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={desc} />
		<meta property="og:site_name" content="Fulfex" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:image" content={`${url.origin}/favicon.svg`} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={desc} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'SoftwareApplication',
			name: 'Fulfex',
			applicationCategory: 'BusinessApplication',
			operatingSystem: 'Web',
			description: 'A modern commerce runtime for WordPress and WooCommerce.',
			url: primaryUrl.toString(),
			offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
		})} />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html, body {
		margin: 0; width: 100%; height: 100%;
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
		background: #ffffff; color: #18181b;
		-webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
	}
	* { box-sizing: border-box; }
	::selection { background: rgba(99, 102, 241, 0.35); }
</style>