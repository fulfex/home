---
import fulFexLogo from '../assets/fulfex-logo.svg';

export interface Props { lang: 'en' | 'id'; }
const { lang } = Astro.props;
const isID = lang === 'id';
const otherPath = isID ? '/' : '/id';
const langLabel = isID ? 'EN' : 'ID';
const langFlag = isID
	? '<svg width="16" height="12" viewBox="0 0 16 12"><rect width="16" height="12" fill="#012169"/><rect y="4" width="16" height="4" fill="#fff"/><rect x="6" width="4" height="12" fill="#fff"/><rect y="5" width="16" height="2" fill="#C8102E"/><rect x="7" width="2" height="12" fill="#C8102E"/></svg>'
	: '<svg width="16" height="12" viewBox="0 0 16 12"><rect width="16" height="12" fill="#fff"/><rect y="6" width="16" height="6" fill="#ce1126"/></svg>';

// ── Shared icons (Lucide-style, 1.5 stroke) ──
const ic = {
	wp: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
	woo: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
	ful: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>',
	store: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l1-5h16l1 5M4 9v11a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V9M9 21v-6h6v6"/></svg>',
	users: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
	clock: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
	puzzle: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19.439 7.85c-.049.322.059.658.284.88L22 10.5l-2.5 2.5-1.5-1.5c-.423-.179-.886-.167-1.5 0a2.5 2.5 0 1 1-3-3c.167-.614.179-1.077 0-1.5L13 5.5 10.5 3 9 4.5c-.222.225-.558.333-.88.284a2.5 2.5 0 1 0-3 3c.049.322-.059.658-.284.88L3 10.5"/></svg>',
	cal: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/></svg>',
	code: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
	layout: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>',
	box: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',
	bag: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>',
	grid: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>',
	search: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
	check: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
	shield: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
	server: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>',
	unlock: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>',
	key: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L15 8"/></svg>',
	terminal: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>',
	palette: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>',
	type: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>',
	sliders: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>',
	api: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><circle cx="12" cy="12" r="2"/></svg>',
};

// ── Nav ──
const navFeatures = isID ? 'Fitur' : 'Features';
const btnGetStarted = isID ? 'Mulai' : 'Get Started';

// ── Hero ──
const heroH1a = isID ? 'Pengalaman shop' : 'Shopify-like shop';
const heroH1b = isID ? 'seperti Shopify. Di WordPress.' : 'experience. On WordPress.';
const heroSub = isID
	? 'Fulfex adalah theme WordPress yang mengubah WooCommerce menjadi pengalaman shop premium seperti Shopify. Konfigurasi warna, font, dan branding ala shadcn.'
	: 'A WordPress theme that transforms WooCommerce into a premium, Shopify-like shopping experience. Configure colors, fonts, and branding shadcn-style.';
const heroCTA1 = isID ? 'Mulai' : 'Get Started';
const heroCTA2 = isID ? 'Lihat di GitHub' : 'View on GitHub';
const flowNodes = [
	{ icon: ic.wp, label: 'WordPress' },
	{ icon: ic.woo, label: 'WooCommerce' },
	{ icon: ic.ful, label: isID ? 'Fulfex Theme' : 'Fulfex Theme', highlight: true },
	{ icon: ic.store, label: isID ? 'Shop Experience' : 'Shop Experience' },
	{ icon: ic.users, label: isID ? 'Pelanggan' : 'Customers' },
];

// ── Problem ──
const problemLabel = isID ? 'Masalah' : 'Problem';
const problemH = isID ? 'WooCommerce powerful. Tapi pengalaman shop terasa tertinggal.' : 'WooCommerce is powerful. But the shop experience feels left behind.';
const problemItems = [
	{ icon: ic.clock, text: isID ? 'Theme WooCommerce lambat dan tidak dibuat untuk shop experience modern.' : 'WooCommerce themes are slow and weren\u2019t built for modern shop experiences.' },
	{ icon: ic.puzzle, text: isID ? 'Plugin yang rapuh menghancurkan alur belanja dan checkout.' : 'Fragile plugins that break shopping and checkout flows.' },
	{ icon: ic.cal, text: isID ? 'Tampilan bawaan terasa seperti 2015 — jauh dari Shopify.' : 'Default looks feel like 2015 — far from Shopify.' },
	{ icon: ic.code, text: isID ? 'Customisasi branding butuh keahlian PHP, bukan tooling modern.' : 'Branding customization needs PHP expertise, not modern tooling.' },
];

// ── Solution ──
const solutionLabel = isID ? 'Solusi' : 'Solution';
const solutionH = isID ? 'Theme yang membuat WooCommerce terasa seperti Shopify.' : 'A theme that makes WooCommerce feel like Shopify.';
const solutionSub = isID
	? 'Fulfex adalah theme WordPress yang fokus pada shop experience. Duduk di atas WooCommerce dan mengubah cara pelanggan browse, search, dan beli — sambil menjaga kepemilikan WordPress penuh.'
	: 'Fulfex is a WordPress theme focused on shop experience. It sits on top of WooCommerce and transforms how customers browse, search, and buy — while you keep full WordPress ownership.';
const solutionFlow = [
	{ icon: ic.woo, label: 'WooCommerce' },
	{ icon: ic.ful, label: isID ? 'Fulfex Theme' : 'Fulfex Theme', highlight: true },
	{ icon: ic.palette, label: isID ? 'Branding' : 'Branding' },
	{ icon: ic.store, label: isID ? 'Shop Experience' : 'Shop Experience' },
];

// ── Features ──
const featuresLabel = isID ? 'Fitur' : 'Features';
const featuresH = isID ? 'Pengalaman shop yang pelanggan harapkan. Kontrol yang Anda inginkan.' : 'The shop experience customers expect. The control you want.';
const features = [
	{ icon: ic.layout, title: isID ? 'Shopify-like Experience' : 'Shopify-like Experience', desc: isID ? 'Cepat, polished, fokus konversi — bukan theme WordPress biasa.' : 'Fast, polished, conversion-focused — not a typical WordPress theme.' },
	{ icon: ic.sliders, title: isID ? 'shadcn-style Config' : 'shadcn-style Config', desc: isID ? 'Warna, font, radius, branding — semua dari satu file config.' : 'Colors, fonts, radius, branding — all from one config file.' },
	{ icon: ic.box, title: isID ? 'Component-driven' : 'Component-driven', desc: isID ? 'Komponen reusable, bukan template PHP yang rapuh.' : 'Reusable components, not fragile PHP templates.' },
	{ icon: ic.bag, title: isID ? 'Cart & Checkout' : 'Cart & Checkout', desc: isID ? 'Checkout optimized seperti Shopify — cepat dan tidak mudah rusak.' : 'Shopify-grade checkout — fast and doesn\u2019t break.' },
	{ icon: ic.grid, title: isID ? 'Product Collections' : 'Product Collections', desc: isID ? 'Koleksi dinamis, filtering, dan sorting langsung jalan.' : 'Dynamic collections, filtering, and sorting out of the box.' },
	{ icon: ic.search, title: isID ? 'Search & Filtering' : 'Search & Filtering', desc: isID ? 'Pencarian instan dan filter faceted untuk discovery lebih baik.' : 'Instant search and faceted filtering for better discovery.' },
	{ icon: ic.check, title: isID ? 'WooCommerce Native' : 'WooCommerce Native', desc: isID ? 'Bekerja sebagai theme, bukan plugin. Tanpa migrasi.' : 'Works as a theme, not a plugin. No migration needed.' },
	{ icon: ic.shield, title: isID ? 'Open Source Ownership' : 'Open Source Ownership', desc: isID ? 'Theme Anda, kode Anda, branding Anda. Tanpa lock-in.' : 'Your theme, your code, your branding. No lock-in.' },
];

// ── Developer Experience ──
const devLabel = 'Developer Experience';
const devH = isID ? 'Seperti shadcn yang selalu Anda pakai.' : 'Like the shadcn you always used.';
const devSub = isID
	? 'Set CSS variables. Theme mengikuti otomatis. Workflow yang sama, sintaks yang sama — sekarang untuk theme WordPress Anda.'
	: 'Set CSS variables. The theme follows automatically. Same workflow, same syntax — now for your WordPress theme.';
const compChips = ['<ProductCard />', '<CartDrawer />', '<ProductGallery />', '<ProductGrid />', '<Checkout />'];
const codeExample = isID
	? '<span class="c-comment">/* theme.css — sama seperti shadcn */</span>\n<span class="c-sel">:root</span> {\n  <span class="c-prop">--background</span>: <span class="c-num">0 0% 4%</span>;\n  <span class="c-prop">--foreground</span>: <span class="c-num">0 0% 98%</span>;\n  <span class="c-prop">--primary</span>: <span class="c-num">239 84% 67%</span>;\n  <span class="c-prop">--radius</span>: <span class="c-num">0.75rem</span>;\n  <span class="c-prop">--font-sans</span>: <span class="c-str">"Inter"</span>;\n}'
	: '<span class="c-comment">/* theme.css — just like shadcn */</span>\n<span class="c-sel">:root</span> {\n  <span class="c-prop">--background</span>: <span class="c-num">0 0% 4%</span>;\n  <span class="c-prop">--foreground</span>: <span class="c-num">0 0% 98%</span>;\n  <span class="c-prop">--primary</span>: <span class="c-num">239 84% 67%</span>;\n  <span class="c-prop">--radius</span>: <span class="c-num">0.75rem</span>;\n  <span class="c-prop">--font-sans</span>: <span class="c-str">"Inter"</span>;\n}';

// ── Architecture ──
const archLabel = isID ? 'Arsitektur' : 'Architecture';
const archH = isID ? 'Theme di atas WooCommerce. Bukan pengganti WordPress.' : 'A theme on top of WooCommerce. Not a WordPress replacement.';
const archSub = isID
	? 'WordPress dan WooCommerce tetap sebagai backend. Fulfex adalah theme yang mengubah tampilan dan pengalaman shop — tanpa mengganti infrastruktur Anda.'
	: 'WordPress and WooCommerce stay as the backend. Fulfex is a theme that transforms the shop experience — without replacing your infrastructure.';
const archNote = isID ? 'Berjalan sebagai theme WordPress native. Tidak butuh setup terpisah.' : 'Runs as a native WordPress theme. No separate setup needed.';
const archLayers = [
	{ icon: ic.wp, label: 'WordPress', items: ['CMS', 'Admin', 'Plugins'] },
	{ icon: ic.woo, label: 'WooCommerce', items: ['Products', 'Orders', 'Customers', 'Checkout'] },
	{ icon: ic.ful, label: isID ? 'Fulfex Theme' : 'Fulfex Theme', items: ['Shop UI', 'Components', 'Config'], highlight: true },
	{ icon: ic.palette, label: isID ? 'Branding' : 'Branding', items: ['Colors', 'Fonts', 'Radius'] },
	{ icon: ic.store, label: isID ? 'Shop Experience' : 'Shop Experience', items: [] },
];

// ── Open Source ──
const ossLabel = 'Open Source';
const ossH = isID ? 'Template milik Anda. Bukan SaaS yang menyewakan.' : 'A template you own. Not a SaaS you rent.';
const ossValues = [
	{ icon: ic.server, title: isID ? 'Self-Hostable' : 'Self-Hostable', desc: isID ? 'Deploy di mana pun. WordPress Anda, hosting Anda.' : 'Deploy anywhere. Your WordPress, your hosting.' },
	{ icon: ic.puzzle, title: isID ? 'Extensible' : 'Extensible', desc: isID ? 'Tambah atau ubah komponen. Kode ada di repo Anda.' : 'Add or modify components. Code lives in your repo.' },
	{ icon: ic.palette, title: isID ? 'shadcn-style' : 'shadcn-style', desc: isID ? 'Config untuk warna, font, branding — bukan override CSS.' : 'Config for colors, fonts, branding — not CSS overrides.' },
	{ icon: ic.unlock, title: isID ? 'No Vendor Lock-In' : 'No Vendor Lock-In', desc: isID ? 'Fork, ubah, host sendiri. Bebas pergi kapan pun.' : 'Fork, modify, self-host. Free to leave anytime.' },
	{ icon: ic.key, title: isID ? 'WordPress Ownership' : 'WordPress Ownership', desc: isID ? 'WordPress Anda, data Anda, storefront Anda.' : 'Your WordPress, your data, your storefront.' },
	{ icon: ic.terminal, title: isID ? 'Developer-First' : 'Developer-First', desc: isID ? 'TypeScript, komponen bertipe, tooling modern.' : 'TypeScript, typed components, modern tooling.' },
];

// ── Modal ──
const modalTitle = isID ? 'Mulai Perjalanan Anda' : 'Start Your Journey';
const modalDesc = isID
	? 'Hubungi saya di <a href="mailto:me@yan.ad" class="modal-email">me@yan.ad</a> — Saya pengembang tunggal, jadi proyek ini mungkin butuh waktu untuk rilis ke publik.'
	: 'Reach me at <a href="mailto:me@yan.ad" class="modal-email">me@yan.ad</a> — I\u2019m a solo developer, so this project may take some effort to launch publicly.';

// ── Footer ──
const footerTag = isID ? 'Storefront template untuk WordPress' : 'Storefront template for WordPress';
const footerBy = isID ? 'Dibangun oleh pengembang tunggal' : 'Built by a solo developer';
---

<header>
	<div class="container header-inner">
		<div class="logo">
			<img src={fulFexLogo.src} alt="Fulfex" width="28" height="28" />
			<span>Fulfex</span>
		</div>
		<nav>
			<a href="#features">{navFeatures}</a>
			<a href="https://github.com/fulfex/fulfex" target="_blank">GitHub</a>
			<a href={otherPath} class="lang-toggle" set:html={langFlag + langLabel}></a>
			<button class="btn btn-primary btn-sm open-modal">{btnGetStarted}</button>
		</nav>
	</div>
</header>

<!-- ════════ Hero ════════ -->
<section class="hero reveal">
	<div class="container hero-inner">
		<div class="hero-text">
			<span class="badge">Open Source</span>
			<h1>{heroH1a}<br /><span class="gradient">{heroH1b}</span></h1>
			<p class="hero-sub">{heroSub}</p>
			<div class="hero-actions">
				<button class="btn btn-primary open-modal">{heroCTA1}</button>
				<a href="https://github.com/fulfex/fulfex" class="btn btn-ghost" target="_blank">
					<svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
					{heroCTA2}
				</a>
			</div>
		</div>
		<div class="hero-flow" aria-hidden="true">
			{flowNodes.map((node, i) => (
				<>
					<div class={`flow-node${node.highlight ? ' highlight' : ''}`}>
						<span class="flow-icon" set:html={node.icon}></span>
						<span class="flow-label">{node.label}</span>
					</div>
					{i < flowNodes.length - 1 && <div class="flow-line"></div>}
				</>
			))}
		</div>
	</div>
</section>

<!-- ════════ Problem ════════ -->
<section class="problem reveal">
	<div class="container">
		<span class="section-label">{problemLabel}</span>
		<h2>{problemH}</h2>
		<div class="problem-grid">
			{problemItems.map((item) => (
				<div class="problem-card">
					<span class="problem-icon" set:html={item.icon}></span>
					<p>{item.text}</p>
				</div>
			))}
		</div>
	</div>
</section>

<!-- ════════ Solution ════════ -->
<section class="solution reveal">
	<div class="container">
		<span class="section-label">{solutionLabel}</span>
		<h2>{solutionH}</h2>
		<p class="solution-sub">{solutionSub}</p>
		<div class="solution-flow" aria-hidden="true">
			{solutionFlow.map((node, i) => (
				<>
					<div class={`sol-node${node.highlight ? ' highlight' : ''}`}>
						<span class="sol-node-icon" set:html={node.icon}></span>
						<span class="sol-node-label">{node.label}</span>
					</div>
