---
import fulFexLogo from '../assets/fulfex-logo.svg';

export interface Props {
	lang: 'en' | 'id';
}

const { lang } = Astro.props;

const isID = lang === 'id';
const otherLang = isID ? 'en' : 'id';
const otherPath = isID ? '/' : '/id';
const title = isID ? 'Fitur' : 'Features';
const ctaLabel = isID ? 'Mulai' : 'Get Started';

const ossBadge = isID ? 'Open Source' : 'Open Source';
const heroSubtitle = isID
	? 'Solusi fulfillment multi-origin open-source untuk merchant WooCommerce. Atur, alokasi, dan kirim lebih pintar — bukan lebih keras.'
	: 'Open-source multi-origin fulfillment intelligence for WooCommerce merchants. Route, allocate, and ship smarter — not harder.';
const heroSub2 = isID
	? 'Dibangun untuk komunitas, dikembangkan secara transparan.'
	: 'Built for the community, developed in the open.';
const startFree = isID ? 'Dapatkan Early Access' : 'Get Early Access';
const ghStar = isID ? 'Star di GitHub' : 'Star on GitHub';
const sectionTitle = isID ? 'Semua yang Anda butuhkan untuk skala fulfillment' : 'Everything you need to scale fulfillment';
const sectionSub = isID
	? 'Berhenti repot dengan spreadsheet. FulFex mengotomatiskan bagian sulitnya agar Anda bisa fokus mengembangkan bisnis.'
	: 'Stop juggling spreadsheets. FulFex automates the hard parts so you can focus on growing your business.';
const featuresData = [
	{
		icon: 'multi-origin',
		title: 'Multi-Origin Routing',
		desc: isID
			? 'Hubungkan unlimited gudang dan dropshipper. Routing pesanan ke origin optimal berdasarkan lokasi, stok, dan biaya.'
			: 'Connect unlimited warehouses and dropshippers. Route orders to the optimal origin based on location, inventory, and cost.'
	},
	{
		icon: 'smart-stock',
		title: 'Smart Stock Assignment',
		desc: isID
			? 'Distribusi inventaris pintar antar lokasi. Tidak perlu khawatir oversell atau kehabisan stok.'
			: 'Intelligent inventory distribution across locations. Never oversell or miss a fulfillment window again.'
	},
	{
		icon: 'scheduling',
		title: 'Smart Scheduling',
		desc: isID
			? 'Otomatiskan cut-off time, preferensi kurir, dan aturan pengiriman per origin. Tepat waktu, setiap saat.'
			: 'Automate cut-off times, carrier preferences, and shipping rules per origin. Deliver on time, every time.'
	},
	{
		icon: 'woocommerce',
		title: 'WooCommerce Native',
		desc: isID
			? 'Integrasi plugin seamless dengan toko WooCommerce Anda. Setup dalam hitungan menit, bukan hari.'
			: 'Seamless plugin integration with your existing WooCommerce store. Set up in minutes, not days.'
	},
	{
		icon: 'analytics',
		title: 'Real-Time Analytics',
		desc: isID
			? 'Dashboard dengan live routing pesanan, level stok, performa kurir, dan insight biaya per pesanan.'
			: 'Dashboard with live order routing, inventory levels, carrier performance, and cost-per-order insights.'
	},
	{
		icon: 'api',
		title: 'Open API',
		desc: isID
			? 'Integrasi dengan tech stack Anda via RESTful APIs. Bangun workflow kustom di atas FulFex.'
			: 'Extend and integrate with your existing tech stack via RESTful APIs. Build custom workflows on top of FulFex.'
	}
];
const modalTitle = isID ? 'Dapatkan Early Access' : 'Get Early Access';
const modalDesc = isID
	? 'Hubungi saya di <a href="mailto:me@yan.ad" class="modal-email">me@yan.ad</a> — Saya pengembang tunggal, jadi proyek ini mungkin butuh waktu untuk rilis ke publik.'
	: 'Reach me at <a href="mailto:me@yan.ad" class="modal-email">me@yan.ad</a> — I\'m a solo developer, so this project may take some effort to launch publicly.';
const footerTag = isID ? 'Fulfillment Orchestrator untuk WooCommerce' : 'Fulfillment Orchestrator for WooCommerce';
const langLabel = isID ? 'EN' : 'ID';
const langFlag = isID
	? '<svg width="16" height="12" viewBox="0 0 16 12"><rect width="16" height="12" fill="#012169"/><rect y="4" width="16" height="4" fill="#fff"/><rect x="6" width="4" height="12" fill="#fff"/><rect y="5" width="16" height="2" fill="#C8102E"/><rect x="7" width="2" height="12" fill="#C8102E"/></svg>'
	: '<svg width="16" height="12" viewBox="0 0 16 12"><rect width="16" height="12" fill="#fff"/><rect y="6" width="16" height="6" fill="#ce1126"/></svg>';
---

<header>
	<div class="container header-inner">
		<div class="logo">
			<img src={fulFexLogo.src} alt="FulFex" width="36" height="36" />
			<span>FulFex</span>
		</div>
		<nav>
			<a href="#features">{title}</a>
			<a href={otherPath} class="lang-toggle" set:html={langFlag + langLabel}></a>
			<a href="#cta" class="btn btn-primary btn-sm">{ctaLabel}</a>
		</nav>
	</div>
</header>

<section class="hero">
	<div class="hero-glow"></div>
	<div class="container">
		<div class="hero-content">
			<a href="https://github.com/fulfex/fulfex" class="oss-badge" target="_blank">
				<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
				{ossBadge}
			</a>
			<div class="hero-logo">
				<img src={fulFexLogo.src} alt="FulFex" width="96" height="96" />
			</div>
			<h1><span class="gradient-text">Fulfillment Orchestrator</span></h1>
			<p class="hero-subtitle">{heroSubtitle}</p>
			<p class="hero-sub2">{heroSub2}</p>
			<div class="hero-actions">
				<a href="#cta" class="btn btn-primary">{startFree}</a>
				<a href="https://github.com/fulfex/fulfex" class="btn btn-github" target="_blank">
					<svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
					{ghStar}
				</a>
			</div>
		</div>
	</div>
</section>

<section id="features" class="features">
	<div class="container">
		<h2 class="section-title">{sectionTitle}</h2>
		<p class="section-subtitle">{sectionSub}</p>
		<div class="features-grid">
			{
				featuresData.map((f) => (
					<div class="feature-card">
						<div class={`feature-icon ${f.icon}`}>
							{f.icon === 'multi-origin' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20z"/><path d="M2 12h20"/></svg>}
							{f.icon === 'smart-stock' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>}
							{f.icon === 'scheduling' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/></svg>}
							{f.icon === 'woocommerce' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>}
							{f.icon === 'analytics' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>}
							{f.icon === 'api' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>}
						</div>
						<h3>{f.title}</h3>
						<p>{f.desc}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

	<section id="cta" class="cta">
		<div class="container">
			<div class="cta-card">
				<h2>{modalTitle}</h2>
				<p>{isID ? 'Klik tombol di bawah untuk menghubungi saya.' : 'Click the button below to reach out.'}</p>
				<button class="btn btn-primary open-modal">{isID ? 'Hubungi via Email' : 'Contact via Email'}</button>
			</div>
		</div>
	</section>

	<div id="modal" class="modal-overlay">
		<div class="modal">
			<button class="modal-close" id="modal-close">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
			<div class="modal-icon">
				<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
			</div>
			<h3 class="modal-title">{modalTitle}</h3>
			<p class="modal-desc" set:html={modalDesc}></p>
			<a href="mailto:me@yan.ad" class="btn btn-primary modal-cta">{isID ? 'Kirim Email' : 'Send Email'}</a>
		</div>
	</div>

	<footer>
	<div class="container footer-inner">
		<div class="footer-brand">
			<div class="logo">
				<img src={fulFexLogo.src} alt="FulFex" width="20" height="20" />
				<span>FulFex</span>
			</div>
			<p>{footerTag}</p>
		</div>
		<p class="footer-copy">&copy; 2026 FulFex.</p>
	</div>
</footer>

<script>
	document.addEventListener('click', (e) => {
		const modal = document.getElementById('modal');
		if (e.target.closest('.open-modal')) {
			modal.classList.add('open');
		} else if (e.target.closest('#modal-close') || e.target === modal) {
			modal.classList.remove('open');
		}
	});
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') document.getElementById('modal').classList.remove('open');
	});
</script>

<style>
	.container {
		max-width: 1120px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 12px 28px;
		border-radius: 10px;
		font-weight: 600;
		font-size: 15px;
		text-decoration: none;
		transition: all 0.2s;
		cursor: pointer;
		border: none;
		font-family: inherit;
	}

	.btn-primary {
		background: linear-gradient(135deg, #a448fe, #655cfb);
		color: #fff;
		box-shadow: 0 4px 20px rgba(164, 72, 254, 0.35);
	}

	.btn-primary:hover {
		box-shadow: 0 6px 28px rgba(164, 72, 254, 0.5);
		transform: translateY(-1px);
	}

	.btn-outline {
		background: transparent;
		color: #c4b5fd;
		border: 1px solid rgba(196, 181, 253, 0.3);
	}

	.btn-outline:hover {
		border-color: rgba(196, 181, 253, 0.6);
		background: rgba(196, 181, 253, 0.06);
	}

	.btn-sm {
		padding: 8px 18px;
		font-size: 14px;
	}

	.section-title {
		font-size: 2rem;
		font-weight: 700;
		text-align: center;
		margin: 0 0 12px;
		letter-spacing: -0.02em;
	}

	.section-subtitle {
		font-size: 1.05rem;
		color: #94a3b8;
		text-align: center;
		max-width: 560px;
		margin: 0 auto 56px;
		line-height: 1.6;
	}

	.gradient-text {
		background: linear-gradient(135deg, #dc96ff, #655cfb);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	header {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 100;
		background: rgba(10, 10, 15, 0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 10px;
		font-size: 1.2rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.logo img {
		display: block;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	nav a {
		color: #c4b5fd;
		text-decoration: none;
		font-size: 14px;
		font-weight: 500;
		transition: color 0.2s;
	}

	nav a:hover {
		color: #fff;
	}

	.lang-toggle {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 4px 8px;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: #94a3b8;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.02em;
		transition: all 0.2s;
	}

	.lang-toggle:hover {
		border-color: rgba(164, 72, 254, 0.3);
		color: #c084fc;
	}

	.hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}

	.hero-glow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 800px;
		height: 800px;
		background: radial-gradient(circle, rgba(164, 72, 254, 0.12) 0%, rgba(101, 92, 251, 0.06) 40%, transparent 70%);
		pointer-events: none;
	}

	.hero-content {
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.oss-badge {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 14px;
		border-radius: 999px;
		border: 1px solid rgba(164, 72, 254, 0.2);
		background: rgba(164, 72, 254, 0.08);
		color: #c084fc;
		font-size: 13px;
		font-weight: 600;
		text-decoration: none;
		margin-bottom: 32px;
		transition: all 0.2s;
	}

	.oss-badge:hover {
		border-color: rgba(164, 72, 254, 0.4);
		background: rgba(164, 72, 254, 0.12);
	}

	.hero-logo {
		margin-bottom: 28px;
		display: flex;
		justify-content: center;
	}

	.hero-logo img {
		display: block;
		border-radius: 50%;
		box-shadow: 0 0 48px 24px rgba(164, 72, 254, 0.2);
	}

	.hero h1 {
		font-size: 4rem;
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
		margin: 0 0 16px;
	}

	.hero-subtitle {
		font-size: 1.2rem;
		color: #94a3b8;
		max-width: 560px;
		margin: 0 auto 8px;
		line-height: 1.7;
	}

	.hero-sub2 {
		font-size: 0.95rem;
		color: #64748b;
		margin: 0 auto 36px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn-github {
		background: rgba(255, 255, 255, 0.06);
		color: #e2e8f0;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.btn-github:hover {
		background: rgba(255, 255, 255, 0.1);
		border-color: rgba(255, 255, 255, 0.18);
	}

	.features {
		padding: 100px 0;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.feature-card {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 16px;
		padding: 32px 28px;
		transition: all 0.25s;
	}

	.feature-card:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: rgba(164, 72, 254, 0.2);
		transform: translateY(-2px);
	}

	.feature-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 52px;
		height: 52px;
		border-radius: 12px;
		margin-bottom: 20px;
	}

	.feature-icon.multi-origin {
		background: rgba(164, 72, 254, 0.15);
		color: #c084fc;
	}

	.feature-icon.smart-stock {
		background: rgba(101, 92, 251, 0.15);
		color: #a5b4fc;
	}

	.feature-icon.scheduling {
		background: rgba(220, 150, 255, 0.15);
		color: #e9d5ff;
	}

	.feature-icon.woocommerce {
		background: rgba(164, 72, 254, 0.12);
		color: #c084fc;
	}

	.feature-icon.analytics {
		background: rgba(101, 92, 251, 0.12);
		color: #a5b4fc;
	}

	.feature-icon.api {
		background: rgba(220, 150, 255, 0.12);
		color: #e9d5ff;
	}

	.feature-card h3 {
		font-size: 1.1rem;
		font-weight: 600;
		margin: 0 0 10px;
	}

	.feature-card p {
		font-size: 0.9rem;
		color: #94a3b8;
		line-height: 1.6;
		margin: 0;
	}

	.cta {
		padding: 80px 0 100px;
	}

	.cta-card {
		background: linear-gradient(135deg, rgba(164, 72, 254, 0.08), rgba(101, 92, 251, 0.08));
		border: 1px solid rgba(164, 72, 254, 0.15);
		border-radius: 24px;
		padding: 64px 48px;
		text-align: center;
		max-width: 640px;
		margin: 0 auto;
	}

	.cta-card h2 {
		font-size: 1.8rem;
		font-weight: 700;
		margin: 0 0 12px;
		letter-spacing: -0.02em;
	}

	.cta-card p {
		color: #94a3b8;
		font-size: 1rem;
		line-height: 1.6;
		margin: 0 0 32px;
	}

	.cta-form {
		display: flex;
		gap: 12px;
		max-width: 440px;
		margin: 0 auto;
	}

	.cta-form input {
		flex: 1;
		padding: 12px 18px;
		border-radius: 10px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.04);
		color: #fff;
		font-size: 15px;
		font-family: inherit;
		outline: none;
		transition: border-color 0.2s;
	}

	.cta-form input::placeholder {
		color: #64748b;
	}

	.cta-form input:focus {
		border-color: rgba(164, 72, 254, 0.4);
	}

	/* ── Modal ── */
	.modal-overlay {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 200;
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(8px);
	}

	.modal-overlay.open {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px;
	}

	.modal {
		position: relative;
		background: #13131a;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 20px;
		padding: 48px 40px 40px;
		max-width: 420px;
		width: 100%;
		text-align: center;
	}

	.modal-close {
